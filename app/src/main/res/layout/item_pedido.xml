<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/cream_dark"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tvIdPedido"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="#ABC123"
                android:textColor="@color/charcoal"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvEstadoPedido"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pendiente"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:background="@drawable/badge_gold"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvInfoAsignacion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mesa 3"
            android:textColor="@color/charcoal_light"
            android:textSize="13sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvItemsResumen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2x Pasta, 1x Agua"
            android:textColor="@color/warm_gray"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvTotalPedido"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="$0.00"
                android:textColor="@color/gold"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <!-- Botón Entregar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEntregar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Entregar"
                android:textColor="@color/charcoal"
                android:textSize="12sp"
                app:strokeColor="@color/charcoal"
                app:strokeWidth="1dp"
                app:cornerRadius="20dp"
                android:layout_marginEnd="8dp"/>

            <!-- Botón Pagar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPagar"
                style="@style/RestaurantButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pagar"
                android:textSize="12sp"
                android:paddingHorizontal="16dp"/>
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>