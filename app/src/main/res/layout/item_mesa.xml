<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/cream_dark"
        android:padding="16dp">

        <!-- Número grande -->
        <TextView
            android:id="@+id/tvNumeroMesa"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:text="1"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/circle_gold"
            android:textColor="@color/charcoal"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mesa"
            android:textColor="@color/warm_gray"
            android:textSize="11sp"
            android:letterSpacing="0.1"/>

        <!-- Capacidad -->
        <TextView
            android:id="@+id/tvCapacidad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👤 4"
            android:textColor="@color/charcoal_light"
            android:textSize="12sp"
            android:layout_marginTop="4dp"/>

        <!-- Estado -->
        <TextView
            android:id="@+id/tvEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Libre"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingHorizontal="12dp"
            android:paddingVertical="3dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/badge_gold"/>

        <!-- Botones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="12dp">

            <ImageButton
                android:id="@+id/btnEditar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_edit"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/charcoal_light"
                android:layout_marginEnd="12dp"/>

            <ImageButton
                android:id="@+id/btnEliminar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/error_red"/>
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>